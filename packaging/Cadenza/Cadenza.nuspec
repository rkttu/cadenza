<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata minClientVersion="5.0">
    <id>Cadenza</id>
    <version>$version$</version>
    <title>Cadenza SDK</title>
    <authors>$authors$</authors>
    <owners>$authors$</owners>
    <description>Single-file scripting SDK for .NET 10+ console scripts. Use with `#:sdk Cadenza@1.0.9` in file-based apps (replace with latest version — MSBuild SDK refs require exact versions).</description>
    <summary>MSBuild SDK for .NET 10 file-based console scripts.</summary>
    <projectUrl>$projectUrl$</projectUrl>
    <repository type="git" url="$repositoryUrl$" commit="$commit$" />
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <copyright>$copyright$</copyright>
    <tags>cadenza msbuild sdk scripting console dotnet file-based-apps single-file</tags>
    <readme>README.md</readme>
    <packageTypes>
      <packageType name="MSBuildSdk" />
    </packageTypes>
  </metadata>
  <files>
    <file src="Sdk\Sdk.props"   target="Sdk\Sdk.props" />
    <file src="Sdk\Sdk.targets" target="Sdk\Sdk.targets" />
    <file src="..\..\src\core\**\*.cs" target="content\core" />
    <file src="README.md" target="" />
    <file src="README.ko.md" target="" />
  </files>
</package>
