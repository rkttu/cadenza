<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata minClientVersion="5.0">
    <id>Cadenza.Web</id>
    <version>$version$</version>
    <title>Cadenza.Web SDK</title>
    <authors>$authors$</authors>
    <owners>$authors$</owners>
    <description>Single-file scripting SDK for .NET 10+ web / Minimal API scripts. Use with `#:sdk Cadenza.Web@1.*` in file-based apps.</description>
    <summary>MSBuild SDK for .NET 10 file-based web scripts.</summary>
    <projectUrl>$projectUrl$</projectUrl>
    <repository type="git" url="$repositoryUrl$" commit="$commit$" />
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <copyright>$copyright$</copyright>
    <tags>cadenza msbuild sdk scripting web minimal-api aspnetcore dotnet file-based-apps</tags>
    <readme>README.md</readme>
    <packageTypes>
      <packageType name="MSBuildSdk" />
    </packageTypes>
  </metadata>
  <files>
    <file src="Sdk\Sdk.props"   target="Sdk\Sdk.props" />
    <file src="Sdk\Sdk.targets" target="Sdk\Sdk.targets" />
    <file src="..\..\src\core\**\*.cs" target="content\core" />
    <file src="..\..\src\web\**\*.cs"  target="content\web" />
    <file src="README.md" target="" />
  </files>
</package>
